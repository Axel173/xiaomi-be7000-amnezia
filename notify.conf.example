# notify.conf — настройки почты для notify.sh (Яндекс SMTP).
#
# Скопируй этот файл в notify.conf РЯДОМ со скриптом и впиши пароль приложения:
#   cp notify.conf.example notify.conf
#   chmod 600 notify.conf      # важно: внутри пароль
#
# Пароль приложения (НЕ основной пароль аккаунта!):
#   Яндекс Почта → Настройки → Безопасность → "Пароли приложений"
#   → создать для "Почта (IMAP/SMTP)". Это 16-символьный токен, который
#   можно отозвать в любой момент, и доступ у него только к почте.

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=ваш_логин@yandex.ru
SMTP_PASS=
MAIL_TO=ваш_логин@yandex.ru
