# iplist.conf — источник списка IP-подсетей для iplist-update.sh.
#
# Файл ОПЦИОНАЛЕН. Нет файла → поведение по умолчанию: тянется ВЕСЬ список
# cidr4 с iplist.opencck.org (как было всегда). Копируй рядом со скриптом,
# только если хочешь сузить/сменить источник:
#   cp iplist.conf.example iplist.conf
#
# Лежит на /data → переживает ребут. После правки изменения подхватятся при
# следующем запуске iplist-update.sh (ближайший ребут или ежедневный 5:00),
# либо принудительно сейчас:  /data/usr/app/awg/iplist-update.sh
#
# БЕЗОПАСНОСТЬ при недоступности источника (в т.ч. в 5 утра): боевой список НЕ
# рушится. set наполнен → остаётся прошлый список; set пуст (после ребута) →
# поднимается локальный снимок .iplist.snapshot. Роутер и интернет не страдают.

# --- Вариант 1: только конкретные сайты ------------------------------------
# Список сайтов через пробел; из них соберётся &site=... к opencck. Удобно,
# если нужны, например, только Steam. Доступные сайты — на
# https://iplist.opencck.org .
#IPLIST_SITES="steampowered.com steamcommunity.com"

# --- Вариант 2: полный свой URL (приоритетнее IPLIST_SITES) -----------------
# Полный контроль / другой источник. Должен отдавать CIDR построчно (format=text).
#IPLIST_URL="https://iplist.opencck.org/?format=text&data=cidr4&site=steampowered.com&site=steamcommunity.com"

# --- База для режима сайтов (обычно менять не нужно) ------------------------
#IPLIST_BASE="https://iplist.opencck.org/?format=text&data=cidr4"

# --- Порог «подозрительно мало строк» --------------------------------------
# Если источник вернул меньше строк — обновление отклоняется как сбой, чтобы не
# затереть рабочий список страницей-ошибкой. При узком IPLIST_SITES снизь порог
# (один маленький сайт может дать <10 строк). По умолчанию 10.
#IPLIST_MIN_LINES=10
