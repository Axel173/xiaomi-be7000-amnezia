# awg.conf.example — ШАБЛОН конфига AmneziaWG для установщика be7000.
#
# КАК ПОЛЬЗОВАТЬСЯ:
#   1. Скопируй этот файл рядом со скриптами под именем awg.conf:
#        cp awg.conf.example awg.conf      (или просто переименуй копию)
#   2. Подставь свои значения из конфига, который выдал VPS / AmneziaVPN.
#   3. Запусти be7000.bat -> установка (или пункт 30/31 в меню).
#
# awg.conf — СЕКРЕТ (приватный ключ). Он в .gitignore и в публичный репозиторий
# НЕ попадает; в git лежит только этот .example без ключей. Так же не коммить
# configs/<страна>.conf — это тоже конфиги с ключами.
#
# Несколько стран: положи такие же файлы в configs/<страна>.conf (тот же формат,
# свои ключи/Endpoint), переключение между ними — пункт 9 меню.
#
# AWG 1.0 или 2.0? Если в твоём конфиге есть S3/S4, диапазоны вида H1 = 123-456
# или ЗАПОЛНЕННОЕ I1 = <b 0x...> — это AWG 2.0 (нужны свежие бинарники, см.
# инструкцию, ШАГ 4.5). Пустые I1..I5 установщик чистит сам.

[Interface]
PrivateKey = <ТВОЙ_ПРИВАТНЫЙ_КЛЮЧ>
Address = 10.8.0.2/32
DNS = 1.1.1.1
# Поля Jc..H4 — это и превращает обычный WireGuard в AmneziaWG. Возьми их
# из своего конфига как есть (значения ниже — пример, не рабочие).
Jc = 4
Jmin = 40
Jmax = 70
S1 = 50
S2 = 100
H1 = 1234567890
H2 = 2345678901
H3 = 3456789012
H4 = 4567890123

[Peer]
PublicKey = <ПУБЛИЧНЫЙ_КЛЮЧ_VPS>
# PresharedKey опционален — если его нет, удали строку целиком.
PresharedKey = <ОПЦИОНАЛЬНО>
AllowedIPs = 0.0.0.0/0
Endpoint = your.vps.ip:51820
PersistentKeepalive = 25
